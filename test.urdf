  <link name="velodyne">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.0377"/>
      <geometry>
        <mesh filename="package://velodyne_description/meshes/VLP16_scan.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0"/>
      </geometry>
    </collision>
  </link>
  <!-- Gazebo requires the velodyne_gazebo_plugins package -->
  <gazebo reference="velodyne">
    <sensor name="velodyne-VLP16" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1875</samples>
            <resolution>1</resolution>
            <min_angle>-3.141592653589793</min_angle>
            <max_angle>3.141592653589793</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>1</resolution>
            <min_angle>-0.2617993877991494</min_angle>
            <max_angle> 0.2617993877991494</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>131.0</max>
          <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.0</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_velodyne_laser.so" name="gazebo_ros_laser_controller">
        <topicName>mid/points</topicName>
        <frameName>velodyne</frameName>
        <organize_cloud>False</organize_cloud>
        <min_range>0.9</min_range>
        <max_range>130.0</max_range>
        <gaussianNoise>0.008</gaussianNoise>
      </plugin>
    </sensor>
  </gazebo>
  <!-- 
    Add Cameras. 
    - JACKAL_FLEA3
    - JACKAL_STEREO_FLEA3
    - JACKAL_BB2
  -->
  <link name="front_camera">
    <inertial>
      <mass value="0.085"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.0754 0.029 0.029"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.0754 0.029 0.029"/>
      </geometry>
    </collision>
  </link>
  <link name="front_camera_optical"/>
  <joint name="front_camera_optical_joint" type="fixed">
    <origin rpy="-1.570796 0 -1.570796" xyz="0 0 0"/>
    <parent link="front_camera"/>
    <child link="front_camera_optical"/>
  </joint>
  <!-- Gazebo -->
  <gazebo reference="front_camera_optical">
    <material>Gazebo/Grey</material>
    <sensor name="front" type="camera">
      <update_rate>60</update_rate>
      <camera name="front">
        <pose>0 0 0 0 -1.5707 1.5707</pose>
        <horizontal_fov>1.0471975512</horizontal_fov>
        <image>
          <width>640</width>
          <height>512</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.5</near>
          <far>300</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_controller">
        <alwaysOn>true</alwaysOn>
        <updateRate>60</updateRate>
        <cameraName>front</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>front_camera_optical</frameName>
        <hackBaseline>0.07</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>
  <link name="front_camera_mount">
    <visual>
      <origin rpy="1.5707 0 1.5707" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jackal_description/meshes/camera-bracket.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  <link name="front_camera_beam">
    <visual>
      <origin rpy="0 0 1.5707" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jackal_description/meshes/camera-beam.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  <joint name="front_camera_pivot_joint" type="fixed">
    <origin rpy="0 0.0 0" xyz="0.102 0 0.008"/>
    <parent link="front_camera_mount"/>
    <child link="front_camera_beam"/>
  </joint>
  <gazebo reference="front_camera_beam">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="front_camera_mount">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <joint name="front_camera_mount_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="front_mount"/>
    <child link="front_camera_mount"/>
  </joint>
  <joint name="front_camera_bracket_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.020 0 0.0245"/>
    <parent link="front_camera_beam"/>
    <child link="front_camera"/>
  </joint>

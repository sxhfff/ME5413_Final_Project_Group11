<launch>
  <arg name="enable_rviz" default="true"/>
  <arg name="pointcloud_topic" default="/mid/points"/>

  <!--
    Isolated A-LOAM entry for the HDL-32E Jackal experiment.
    This assumes the external package is available as `aloam_velodyne`
    and leaves all FAST-LIO paths untouched.
  -->

  <param name="scan_line" type="int" value="32" />
  <param name="mapping_skip_frame" type="int" value="1" />
  <param name="minimum_range" type="double" value="0.3" />
  <param name="maximum_range" type="double" value="18.0" />
  <param name="mapping_line_resolution" type="double" value="0.2" />
  <param name="mapping_plane_resolution" type="double" value="0.4" />

  <node pkg="aloam_velodyne"
        type="ascanRegistration"
        name="ascanRegistration"
        output="screen">
    <remap from="/velodyne_points" to="$(arg pointcloud_topic)"/>
  </node>

  <node pkg="aloam_velodyne"
        type="alaserOdometry"
        name="alaserOdometry"
        output="screen" />

  <node pkg="aloam_velodyne"
        type="alaserMapping"
        name="alaserMapping"
        output="screen" />

  <node if="$(arg enable_rviz)"
        launch-prefix="nice"
        pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find aloam_velodyne)/rviz_cfg/aloam_velodyne.rviz"
        output="log"/>
</launch>

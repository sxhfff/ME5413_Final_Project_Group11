<launch>
  <arg name="enable_rviz" default="true"/>
  <arg name="fastlio_cloud_topic" default="/mid/points"/>
  <arg name="fastlio_imu_topic" default="/imu/data"/>

  <!--
    Default to raw Velodyne cloud because it is already in the robot TF tree.
    /cloud_registered and /cloud_registered_body remain available for experiments,
    but they are more sensitive to FAST-LIO frame conventions.
  -->
  <arg name="projection_cloud_topic" default="/mid/points"/>
  <arg name="scan_topic" default="/scan"/>
  <arg name="scan_target_frame" default="base_link"/>

  <!--
    Default mode for whole-building mapping.
    Keep a moderately narrow slice around lidar height so the scan remains
    usable on flat floors while reducing some stair-induced overlap.
  -->
  <arg name="min_height" default="0.12"/>
  <arg name="max_height" default="0.42"/>
  <arg name="angle_min" default="-3.14159"/>
  <arg name="angle_max" default="3.14159"/>
  <arg name="angle_increment" default="0.0087"/>
  <arg name="scan_time" default="0.1"/>
  <arg name="range_min" default="0.35"/>
  <arg name="range_max" default="10.0"/>

  <!-- FAST-LIO -->
  <include file="$(find me5413_world)/launch/include/fast_lio_slam.launch">
    <arg name="pointcloud_topic" value="$(arg fastlio_cloud_topic)"/>
    <arg name="imu_topic" value="$(arg fastlio_imu_topic)"/>
    <arg name="bridge_fastlio_to_robot_tf" value="true"/>
  </include>

  <!-- Convert FAST-LIO cloud into 2D scan for gmapping -->
  <include file="$(find me5413_world)/launch/include/pointcloud_to_scan.launch">
    <arg name="pointcloud_topic" value="$(arg projection_cloud_topic)"/>
    <arg name="scan_topic" value="$(arg scan_topic)"/>
    <arg name="target_frame" value="$(arg scan_target_frame)"/>
    <arg name="min_height" value="$(arg min_height)"/>
    <arg name="max_height" value="$(arg max_height)"/>
    <arg name="angle_min" value="$(arg angle_min)"/>
    <arg name="angle_max" value="$(arg angle_max)"/>
    <arg name="angle_increment" value="$(arg angle_increment)"/>
    <arg name="scan_time" value="$(arg scan_time)"/>
    <arg name="range_min" value="$(arg range_min)"/>
    <arg name="range_max" value="$(arg range_max)"/>
  </include>

  <!-- 2D SLAM map -> odom -->
  <include file="$(find me5413_world)/launch/include/gmapping_fastlio_2d.launch">
    <arg name="scan_topic" value="$(arg scan_topic)"/>
    <arg name="odom_frame" value="odom"/>
    <arg name="base_frame" value="base_link"/>
    <arg name="map_frame" value="map"/>
  </include>

  <node if="$(arg enable_rviz)"
        pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find me5413_world)/rviz/fastlio_gmapping_2d.rviz"
        output="log"/>
</launch>

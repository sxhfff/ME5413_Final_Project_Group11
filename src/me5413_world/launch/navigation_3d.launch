<launch>

  <!--
    Full navigation stack using:
    - Gazebo world with default jackal_control EKF disabled
    - FLOAM local lidar odometry
    - robot_localization fusion of wheel + IMU + lidar odom
    - 2D map server + AMCL for map -> odom
    - move_base for planning/control
  -->

  <arg name="map_file" default="$(find me5413_world)/maps/manual_cut_direct_2d_map_v3_thick.yaml"/>
  <arg name="points_topic" default="/mid/points" />
  <arg name="lidar_frame_id" default="velodyne" />
  <arg name="amcl_scan_topic" default="/local_obstacle_scan" />
  <arg name="spawn_yaw" default="0.0" />
  <arg name="initial_pose_x" default="0.0" />
  <arg name="initial_pose_y" default="0.0" />
  <arg name="initial_pose_a" default="1.5708" />

<!-- 1.5708 -->
  <include file="$(find me5413_world)/launch/world_3d_fusion.launch">
    <arg name="spawn_yaw" value="$(arg spawn_yaw)" />
  </include>
  <include file="$(find me5413_world)/launch/localization_3d_fusion.launch">
    <arg name="points_topic" value="$(arg points_topic)" />
    <arg name="lidar_frame_id" value="$(arg lidar_frame_id)" />
  </include>

  <!-- Connect the robot to a keyboard teleop controller -->
  <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" output="screen" respawn="true"/>

  <!-- Run the map server -->
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)" />

  <!-- Keep AMCL for global map -> odom localization, but it now benefits from the improved odom estimate. -->
  <include file="$(find me5413_world)/launch/include/amcl_with_initial_pose.launch">
    <arg name="scan_topic" value="$(arg amcl_scan_topic)" />
    <arg name="initial_pose_x" value="$(arg initial_pose_x)" />
    <arg name="initial_pose_y" value="$(arg initial_pose_y)" />
    <arg name="initial_pose_a" value="$(arg initial_pose_a)" />
  </include>

  <node pkg="me5413_world" type="pointcloud_to_scan_node.py" name="pointcloud_to_scan_node" output="screen">
    <param name="input_topic" value="/mid/points" />
    <param name="output_topic" value="/local_obstacle_scan" />
    <param name="scan_frame" value="velodyne" />
    <param name="min_height" value="-0.10" />
    <param name="max_height" value="0.30" />
    <param name="min_range" value="1.2" />
    <param name="max_range" value="8.0" />
    <param name="robot_exclusion_radius" value="0.9" />
    <param name="angle_min" value="-3.14159" />
    <param name="angle_max" value="3.14159" />
  </node>

  <!-- Override the default local planner to track the global path more promptly. -->
  <rosparam file="$(find me5413_world)/config/base_local_planner_params_tracking.yaml" command="load" />

  <!-- Launch Move Base -->
  <include file="$(find me5413_world)/launch/include/move_base_local_scan.launch" />

  <!-- Launch Rviz with our settings -->
  <node type="rviz" name="rviz" pkg="rviz" args="-d $(find me5413_world)/rviz/navigation.rviz" output="log" respawn="true"/>

  <node ns="me5413_world" pkg="me5413_world" type="goal_publisher_node" name="goal_publisher_node" output="screen" />

</launch>

<launch>

  <!--
    Start the simulation world for the start_robot pipeline while disabling
    the default jackal_control EKF. The 3D fusion stack will provide
    /odometry/filtered separately.
  -->

  <arg name="spawn_yaw" default="0.0" />

  <include file="$(find me5413_world)/launch/world.launch">
    <arg name="enable_ekf" value="false" />
    <arg name="spawn_yaw" value="$(arg spawn_yaw)" />
  </include>

</launch>

<launch>
  <arg name="pointcloud_topic" default="/mid/points"/>
  <arg name="scan_topic" default="/mid/scan"/>
  <arg name="target_frame" default="base_link"/>
  <arg name="min_height" default="-0.10"/>
  <arg name="max_height" default="0.30"/>
  <arg name="angle_min" default="-3.14159"/>
  <arg name="angle_max" default="3.14159"/>
  <arg name="angle_increment" default="0.0087"/>
  <arg name="scan_time" default="0.1"/>
  <arg name="range_min" default="0.3"/>
  <arg name="range_max" default="20.0"/>
  <arg name="use_inf" default="true"/>
  <arg name="inf_epsilon" default="1.0"/>
  <arg name="concurrency_level" default="1"/>

  <node pkg="pointcloud_to_laserscan"
        type="pointcloud_to_laserscan_node"
        name="pointcloud_to_laserscan"
        output="screen">
    <param name="target_frame" value="$(arg target_frame)"/>
    <param name="transform_tolerance" value="0.05"/>
    <param name="min_height" value="$(arg min_height)"/>
    <param name="max_height" value="$(arg max_height)"/>
    <param name="angle_min" value="$(arg angle_min)"/>
    <param name="angle_max" value="$(arg angle_max)"/>
    <param name="angle_increment" value="$(arg angle_increment)"/>
    <param name="scan_time" value="$(arg scan_time)"/>
    <param name="range_min" value="$(arg range_min)"/>
    <param name="range_max" value="$(arg range_max)"/>
    <param name="use_inf" value="$(arg use_inf)"/>
    <param name="inf_epsilon" value="$(arg inf_epsilon)"/>
    <param name="concurrency_level" value="$(arg concurrency_level)"/>
    <remap from="cloud_in" to="$(arg pointcloud_topic)"/>
    <remap from="scan" to="$(arg scan_topic)"/>
  </node>
</launch>
